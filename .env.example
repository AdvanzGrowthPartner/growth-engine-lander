# --- Integración GHL (API v2) ---

# Private Integration Token de GHL (Settings → Private Integrations).
# SECRETO: pegarlo solo en Vercel → Environment Variables, nunca en el repo.
GHL_API_TOKEN=

# Location ID (sub-cuenta) de GHL. No es secreto.
GHL_LOCATION_ID=

# Nombre del pipeline y la etapa donde cae el lead (opcionales — defaults abajo).
GHL_PIPELINE_NAME=Pipeline Advanz
GHL_PIPELINE_STAGE=Nuevo Prospecto

# URL pública del calendario de GHL para el botón "Agendar mi sesión 1:1".
NEXT_PUBLIC_GHL_CALENDAR_URL=

# --- Tracking ---

# Meta Pixel (cliente). Lo saco yo del MCP de Meta si me confirmás la cuenta.
NEXT_PUBLIC_FB_PIXEL_ID=

# Google Analytics 4 (Measurement ID, ej. G-XXXXXXXXXX).
NEXT_PUBLIC_GA4_ID=

# Meta Conversions API (server-side): el mismo Pixel ID + un token de CAPI (secreto).
FB_PIXEL_ID=
FB_CAPI_TOKEN=

