# --- Integración GHL (Fase A) ---

# Webhook de entrada de GHL: en GHL crea un Workflow con trigger
# "Inbound Webhook", copia la URL y pégala acá. Es secreta (solo server-side).
GHL_WEBHOOK_URL=

# URL pública del calendario de GHL para agendar la sesión 1:1.
# Va al botón "Agendar mi sesión 1:1 gratis" del resultado.
NEXT_PUBLIC_GHL_CALENDAR_URL=
